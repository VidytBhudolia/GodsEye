# ===========================================
# GodsEye Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# AIS Stream WebSocket
AIS_STREAM_API_KEY=

# OpenSky Network
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Space-Track / N2YO
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# Groq (LLM)
GROQ_API_KEY=

# SerpAPI (Web Search for LLM)
SERPAPI_API_KEY=

# MapTiler / CartoDB (tile URL)
MAP_TILE_URL=https://a.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info
